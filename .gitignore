# Credentials — never commit the real config
seoul_index_config.json

# Runtime state and generated caches
seoul_index_state.json
sales_agg.json
molit_agg.json

# Card previews written into the working tree by --dry-run
card_*.png
meth_*.png

# Post archive written before a wipe (public text, but not part of the source)
seoul_index_posts_archive.json

# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Accumulated crowd readings (cannot be re-fetched, but local to each machine)
crowd_history.jsonl
crowd_history.jsonl.bak-*

# Leftover from an interrupted atomic JSON write (write_json_atomic)
*.json.tmp

# Single-run lock held by seoul_index_post.py for the length of a run
.post.lock
.post.lock
